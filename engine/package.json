{
  "name": "steckling",
  "version": "0.1.0",
  "description": "A worktree + isolated Docker service stack per git branch, for parallel branch development.",
  "type": "module",
  "bin": {
    "steck": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli.ts --compile --outfile ../dist/steck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
